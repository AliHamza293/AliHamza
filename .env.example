# ─────────────────────────────────────────────────────────────────
# COPY THIS FILE TO .env.local AND FILL IN YOUR VALUES
# Never commit .env.local to GitHub
# ─────────────────────────────────────────────────────────────────

# Admin panel password — choose anything you want
ADMIN_PASSWORD=your_secret_password_here

# Secret key for signing session tokens — make it long and random
# Generate one at: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=your_super_secret_key_here_make_it_long_and_random

# Your site URL (use http://localhost:3000 for local dev)
NEXTAUTH_URL=http://localhost:3000
